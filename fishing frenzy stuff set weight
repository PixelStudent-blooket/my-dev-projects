(async () => {
    const findReactHandler = () => {
        const root = document.querySelector('#app > div > div');
        if (!root) return null;
        for (const key in root) {
            if (key.startsWith('__reactFiber$') || key.startsWith('__reactInternalInstance$')) {
                const fiber = root[key];
                return fiber.child ? fiber.child.stateNode : null;
            }
        }
        return null;
    };

    const handler = findReactHandler();

    if (handler && typeof handler.setState === 'function') {
        try {
            const userInput = window.prompt("blooket.net says?\nhow much weight do you want");
            
            if (userInput !== null && userInput !== "") {
                const targetWeight = parseInt(userInput.replace(/,/g, ''));

                if (!isNaN(targetWeight)) {
                    handler.setState({
                        weight: targetWeight,
                        totalWeight: targetWeight,
                        score: targetWeight
                    }, () => {
                        console.log(`%c [SUCCESS] %c Weight updated to: ${targetWeight}`, "color: #00ff00; font-weight: bold", "color: #ffffff");
                        if (handler.forceUpdate) handler.forceUpdate();
                    });
                } else {
                    alert("Error: Please enter a valid numerical value.");
                }
            }
        } catch (err) {
            console.error("An error occurred while updating state:", err);
        }
    } else {
        alert("Failed to find game stateNode. Ensure you are currently inside a Fishing Frenzy match.");
    }
})();


